# ==========================================
# PROJECT SENTINEL V2 - .gitignore
# ==========================================

# ------------------------------------------
# 1. SENSITIVE DATA (CRITICAL)
# ------------------------------------------

# Sentinel v2 - Storage directories (keys, credentials, wallet data)
sentinel_v2/storage/
sentinel_v2/storage/**
!sentinel_v2/storage/.gitkeep

# Any key files anywhere
*.key
*.pem
*.priv
*.secret
*.jwk
*.jks
*.p12
*.pfx
*.keystore
*.truststore
*_private.*
signing_key.*

# Credential files
*.credential
*.cred
credential.json
credentials.json
*.vcred

# ------------------------------------------
# 2. PYTHON CACHE & COMPILED FILES
# ------------------------------------------

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyz
*.pyzip

# Python cache directories
.Python
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib64/
venv/
env/
ENV/

# ------------------------------------------
# 3. IDE & OS FILES
# ------------------------------------------

# IDE directories
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------
# 4. LOGS & TEMPORARY FILES
# ------------------------------------------

*.log
logs/
*.tmp
*.temp
*.bak
*.backup

# ------------------------------------------
# 5. FLASK & WEB FILES
# ------------------------------------------

# Flask instance folder
instance/
*.sqlite
*.db

# ------------------------------------------
# 6. ENVIRONMENT & CONFIGURATION
# ------------------------------------------

.env
.env.local
.env.*.local
*.env
config.local.py
config.json

# ------------------------------------------
# 7. PROJECT SENTINEL V2 SPECIFIC
# ------------------------------------------

# Storage directories (explicitly ignored)
sentinel_v2/storage/
sentinel_v2/*/__pycache__/
sentinel_v2/**/__pycache__/

# Keep the .gitkeep files to maintain directory structure
!sentinel_v2/storage/.gitkeep
!sentinel_v2/storage/authority/.gitkeep
!sentinel_v2/storage/wallet/.gitkeep

# ------------------------------------------
# 8. TEST & COVERAGE
# ------------------------------------------

.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ------------------------------------------
# 9. DEPLOYMENT & PACKAGING
# ------------------------------------------

*.whl
*.tar.gz
*.tgz
*.zip
*.tar